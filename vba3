Private Function InjectTransitionRemoves(wbOut As Workbook, loSrc As ListObject) As Long
    ' Step 1: Read ALL LOBs from uploads → store LOB:Hash
    Dim loUploads As ListObject
    Set loUploads = FindTable("uploads")
    If loUploads Is Nothing Then Exit Function

    Dim dictOldHash As Object
    Set dictOldHash = CreateObject("Scripting.Dictionary")

    Dim i As Long
    Dim uLOB As String, uHash As String
    Dim cLOB As Long, cHash As Long

    cLOB  = FindColumn(loUploads, "ECP LOB")
    cHash = FindColumn(loUploads, "Hash")

    For i = 1 To loUploads.DataBodyRange.Rows.Count
        uLOB  = Trim(loUploads.DataBodyRange.Cells(i, cLOB).Value)
        uHash = Trim(loUploads.DataBodyRange.Cells(i, cHash).Value)
        If uLOB <> "" And Not dictOldHash.Exists(uLOB) Then
            dictOldHash.Add uLOB, uHash
        End If
    Next i

    If dictOldHash.Count = 0 Then Exit Function

    ' Step 2: Scan user_input for matching LOBs with Hash mismatch
    Dim loInput As ListObject
    Set loInput = FindTable("user_input")

    Dim ciLOB As Long, ciAlign As Long, ciUpload As Long, ciHash As Long
    ciLOB    = FindColumn(loInput, "ECP LOB")
    ciAlign  = FindColumn(loInput, "Alignment Status")
    ciUpload = FindColumn(loInput, "For Upload")
    ciHash   = FindColumn(loInput, "Hash")

    ' Step 3: Get output table
    Dim loOut As ListObject
    Set loOut = wbOut.Sheets(1).ListObjects("Upload")

    Dim coLOB As Long, coAlign As Long, coHash As Long
    coLOB   = FindColumn(loOut, "ECP LOB")
    coAlign = FindColumn(loOut, "Alignment Status")
    coHash  = FindColumn(loOut, "Hash")

    Dim injCount As Long

    For i = 1 To loInput.DataBodyRange.Rows.Count
        Dim curLOB As String, curAlign As String
        Dim curUpload As String, curHash As String
        curLOB    = Trim(loInput.DataBodyRange.Cells(i, ciLOB).Value)
        curAlign  = Trim(loInput.DataBodyRange.Cells(i, ciAlign).Value)
        curUpload = Trim(loInput.DataBodyRange.Cells(i, ciUpload).Value)
        curHash   = Trim(loInput.DataBodyRange.Cells(i, ciHash).Value)

        ' Only inject if LOB exists in uploads AND Hash changed
        If curUpload = "Yes" And dictOldHash.Exists(curLOB) Then
            If curHash <> dictOldHash(curLOB) Then
                Dim newRow As ListRow
                Set newRow = loOut.ListRows.Add
                newRow.Range.Cells(1, coLOB).Value   = curLOB
                newRow.Range.Cells(1, coHash).Value  = dictOldHash(curLOB)
                newRow.Range.Cells(1, coAlign).Value = "Invalid - Remove"
                injCount = injCount + 1
            End If
        End If
    Next i

    InjectTransitionRemoves = injCount
End Function